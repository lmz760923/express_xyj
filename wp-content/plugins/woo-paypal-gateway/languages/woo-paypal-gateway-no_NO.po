msgid ""
"Under <strong>Disable Specific Payment Buttons</strong>, select "
"<strong>Credit or Debit Card</strong> and any other methods you want to "
"hide."
msgstr ""
"Under <strong>Deaktiver spesifikke betalingsknapper</strong>, velg "
"<strong>Kreditt- eller debetkort</strong> og eventuelle andre metoder du vil"
" skjule."

