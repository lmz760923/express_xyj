"Para mostrar solo el botón \"PayPal\" en la página de pago, sigue estos "
"pasos:"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1222
#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1244
msgid "Step 1: Update PayPal Settings"
msgstr "Paso 1: Actualiza la Configuración de PayPal"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1225
msgid ""
"Under <strong>Disable Specific Payment Buttons</strong>, select "
"<strong>Credit or Debit Card</strong> and any other methods you want to hide."
msgstr ""
"Bajo <strong>Deshabilitar Botones de Pago Específicos</strong>, selecciona "
"<strong>Tarjeta de Crédito o Débito</strong> y cualquier otro método que "
"desees ocultar."

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1228
msgid "Step 2: Update Advanced Card Payments Settings"
msgstr "Paso 2: Actualiza la Configuración de Pagos con Tarjeta Avanzada"

