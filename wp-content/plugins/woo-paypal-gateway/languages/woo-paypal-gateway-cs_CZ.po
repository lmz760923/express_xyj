msgstr "Vytvořit účet?"

#: ppcp/public/class-ppcp-paypal-checkout-for-woocommerce-button-manager.php:1289
msgid ""
"Create an account by entering the information below. If you are a returning "
"customer please login at the top of the page."
msgstr ""
"Vytvořte účet zadáním informací níže. Pokud jste se již dříve registrovali, "
"prosím přihlaste se v horní části stránky."

#. translators: %1$s is the payment method title, %2$s is the formatted
#. payment status.
#: ppcp/public/class-ppcp-paypal-checkout-for-woocommerce-button-manager.php:1492
msgid "Payment via %1$s: %2$s."
msgstr "Platba přes %1$s: %2$s."

#. translators: %1$s is the payment method title, %2$s is the pending reason
#. from PayPal.
#: ppcp/public/class-ppcp-paypal-checkout-for-woocommerce-button-manager.php:1509
msgid "Payment via %1$s Pending. PayPal reason: %2$s."
msgstr "Platba přes %1$s čeká. Důvod PayPal: %2$s."

#. translators: %1$s is the payment method title, %2$s is the PayPal
#. transaction ID.
#: ppcp/public/class-ppcp-paypal-checkout-for-woocommerce-button-manager.php:1518
msgid "Payment via %1$s. Transaction ID: %2$s"
msgstr "Platba přes %1$s. ID transakce: %2$s"

#: ppcp/public/class-ppcp-paypal-checkout-for-woocommerce-button-manager.php:1701
msgctxt "Important"
msgid ""
"<strong>You're almost done!</strong><br>Review your information before you "
"place your order."
msgstr ""
"<strong>Jste téměř hotovi!</strong><br>Zkontrolujte své informace, než "
"zadáte svou objednávku."

#: ppcp/public/class-ppcp-paypal-checkout-for-woocommerce-button-manager.php:1756
msgid "Capture Charge"
msgstr "Zachycení poplatku"

#: ppcp/public/class-ppcp-paypal-checkout-for-woocommerce-button-manager.php:1894
msgctxt "Important"
msgid "Cancel order"
msgstr "Zrušit objednávku"

#: ppcp/public/class-ppcp-paypal-checkout-for-woocommerce-button-manager.php:1967
msgid ""
"We cannot process your order with the payment information that you provided. "
"Please use an alternate payment method."
msgstr ""
"Nemůžeme zpracovat vaši objednávku s platebními informacemi, které jste "
"poskytli. Prosím, použijte alternativní platební metodu."

#: ppcp/public/class-ppcp-paypal-checkout-for-woocommerce-button-manager.php:2017
msgid "3D Secure response"
msgstr "Odpověď 3D Secure"
