msgid ""
"Under <strong>Disable Specific Payment Buttons</strong>, select "
"<strong>Credit or Debit Card</strong> and any other methods you want to hide."
msgstr ""
"Onder <strong>Specifieke Betalingsknoppen Uitschakelen</strong>, selecteer "
"<strong>Creditcard of Debitcard</strong> en andere methoden die je wilt "
"verbergen."

