msgid ""
"Choose whether you wish to capture funds immediately or authorize payment "
"only."
msgstr "選擇您希望立即捕捉資金還是僅授權付款。."

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1835
msgid "Capture"
msgstr "捕捉"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1836
msgid "Authorize"
msgstr "授權"

