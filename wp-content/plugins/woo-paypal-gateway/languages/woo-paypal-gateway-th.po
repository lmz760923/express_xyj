#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:452
msgid "Above Proceed to Checkout button"
msgstr "ด้านบนปุ่มดำเนินการชำระเงิน"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:543
msgid "Icon"
msgstr "ไอคอน"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:547
