#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1224
msgid "Go to <strong>PayPal Settings</strong>."
msgstr "Mergi la <strong>Setările PayPal</strong>."

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1209
msgid "Find the <strong>Disable Specific Payment Buttons</strong> setting."
msgstr ""
"Găsiți setarea <strong>Dezactivează butoanele de plată specifice</strong>."

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1210
msgid "Select <strong>Pay Later</strong> from the dropdown list."
msgstr "Selectați <strong>Plătiți mai târziu</strong> din lista derulantă."

