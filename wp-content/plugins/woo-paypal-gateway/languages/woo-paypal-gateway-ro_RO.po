msgid ""
"Under <strong>Disable Specific Payment Buttons</strong>, select "
"<strong>Credit or Debit Card</strong> and any other methods you want to "
"hide."
msgstr ""
"Sub <strong>Dezactivare butoane de plată specifice</strong>, selectați "
"<strong>Card de credit sau debit</strong> și orice alte metode pe care "
"doriți să le ascundeți."

