msgid "Icon"
msgstr "Ikon"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:547
msgid "Monogram (PP)"
msgstr "Monogram (PP)"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:548
