msgstr ""
"នេះគ្រប់គ្រងអ្វីដែលអ្នកប្រើឃើញជាឈ្មោះម៉ាក / ក្រុមហ៊ុននៅទំព័រពិនិត្យ PayPal។"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1898
msgid "Landing Page"
msgstr "ទំព័រចុះចត"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1901
msgid ""
"The type of landing page to show on the PayPal site for customer checkout. "
"PayPal Account Optional must be checked for this option to be used."
msgstr ""
"ប្រភេទទំព័រចុះចតដែលត្រូវបង្ហាញនៅគេហទំព័រ PayPal សម្រាប់ការទូទាត់អតិថិជន។ "
"ត្រូវធីក PayPal Account Optional ដើម្បីប្រើជម្រើសនេះ។"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1902
msgid "Login"
msgstr "ចូល"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1903
msgid "Billing"
msgstr "វិក្កយបត្រ"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1904
msgid "No Preference"
msgstr "គ្មានចំណូលចិត្ត"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1909
msgid "Instant Payments "
msgstr "ការបង់ប្រាក់ភ្លាមៗ "

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1913
msgid ""
"If you enable this setting, PayPal will be instructed not to allow the buyer"
" to use funding sources that take additional time to complete (for example, "
"eChecks). Instead, the buyer will be required to use an instant funding "
"source, such as an instant transfer, a credit/debit card, or PayPal Credit."
msgstr ""
"ប្រសិនបើអ្នកបើកការកំណត់នេះ PayPal "
"នឹងត្រូវបានណែនាំមិនអនុញ្ញាតឱ្យអ្នកទិញប្រើប្រភពថវិកាដែលត្រូវការពេលវេលាបន្ថែម "
"(ឧទាហរណ៍ eChecks)។ ជំនួសវិញ អ្នកទិញនឹងត្រូវបានតម្រូវឱ្យប្រើប្រភពថវិកាភ្លាមៗ "
"ដូចជាការផ្ទេរភ្លាមៗ កាតឥណទាន/ដេបិត ឬ PayPal Credit។"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1916
msgid "Require Instant Payment"
msgstr "តម្រូវឱ្យមានការបង់ប្រាក់ភ្លាមៗ"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1919
msgid "Billing Address"
msgstr "អាសយដ្ឋានវិក្កយបត្រ"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1920
msgid "Use PayPal Shipping Address as Billing"
msgstr "ប្រើអាសយដ្ឋានដឹកជញ្ជូន PayPal ជាវិក្កយបត្រ"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1921
msgid ""
"If the billing address is empty and PayPal provides a shipping address, the "
"order will use the shipping address as the billing address."
msgstr ""
"ប្រសិនបើអាសយដ្ឋានវិក្កយបត្រទទេ ហើយ PayPal ផ្តល់អាសយដ្ឋានដឹកជញ្ជូន "
"ការបញ្ជាទិញនឹងប្រើអាសយដ្ឋានដឹកជញ្ជូនជាអាសយដ្ឋានវិក្កយបត្រ។"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1927
msgid "Send Item Details"
msgstr "ផ្ញើព័ត៌មានលម្អិតនៃទំនិញ"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1928
msgid "Send line item details to PayPal"
msgstr "ផ្ញើព័ត៌មានលម្អិតនៃបន្ទាត់ទំនិញទៅ PayPal"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1930
msgid ""
"Include all line item details in the payment request to PayPal so that they "
"can be seen from the PayPal transaction details page."
msgstr ""
"រួមបញ្ចូលព័ត៌មានលម្អិតនៃបន្ទាត់ទំនិញទាំងអស់នៅក្នុងសំណើបង់ប្រាក់ទៅ PayPal "
"ដើម្បីឱ្យពួកគេអាចមើលបានពីទំព័រព័ត៌មានលម្អិតប្រតិបត្តិការ PayPal។"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1934
msgid "Order Review Page"
msgstr "ទំព័រពិនិត្យការបញ្ជាទិញ"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1935
msgid "Skip Order Review Page"
msgstr "រំលងទំព័រពិនិត្យការបញ្ជាទិញ"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1937
msgid ""
"Payments from the Product or Cart page skip the review step and go straight "
"to the Thank You page."
msgstr ""
"ការបង់ប្រាក់ពីទំព័រផលិតផល ឬរទេះនឹងរំលងជំហានពិនិត្យ ហើយទៅផ្ទាល់ទៅទំព័រអរគុណ។"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1944
msgid "Invoice prefix"
msgstr "បុព្វបទវិក្កយបត្រ"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1946
msgid ""
"Please enter a prefix for your invoice numbers. If you use your PayPal "
"account for multiple stores ensure this prefix is unique as PayPal will not "
"allow orders with the same invoice number."
msgstr ""
"សូមបញ្ចូលបុព្វបទសម្រាប់លេខវិក្កយបត្ររបស់អ្នក។ ប្រសិនបើអ្នកប្រើគណនី PayPal "
"របស់អ្នកសម្រាប់ហាងច្រើន សូមប្រាកដថាបុព្វបទនេះមានលក្ខណៈពិសេស ព្រោះ PayPal "
"នឹងមិនអនុញ្ញាតឱ្យការបញ្ជាទិញដែលមានលេខវិក្កយបត្រដូចគ្នា។"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1951
msgid "Credit Card Statement Name"
msgstr "ឈ្មោះរបាយការណ៍កាតឥណទាន"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1953
msgid ""
"The value entered here will be displayed on the buyer's credit card "
"statement."
msgstr ""
"តម្លៃដែលបានបញ្ចូលនៅទីនេះនឹងត្រូវបានបង្ហាញលើរបាយការណ៍កាតឥណទានរបស់អ្នកទិញ។"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1959
msgid "Debug log"
msgstr "កំណត់ហេតុបំបាត់កំហុស"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1961
msgid "Enable logging"
msgstr "បើកការកត់ត្រា"

#. translators: %s is the path to the WooCommerce PayPal debug log file.
#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:1965
msgid "Log PayPal events, such as Webhook, Payment, Refund inside %s"
msgstr ""
"កត់ត្រាព្រឹត្តិការណ៍ PayPal ដូចជា Webhook, ការបង់ប្រាក់, ការសងវិញនៅក្នុង %s"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-tracking.php:137
msgid "PayPal Shipment Tracking"
msgstr "ការតាមដានការដឹកជញ្ជូន PayPal"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-tracking.php:177
msgid "Transaction Id"
msgstr "លេខប្រតិបត្តិការ"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-tracking.php:181
msgid "Tracking Number*"
msgstr "លេខតាមដាណ*"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-tracking.php:185
msgid "Status"
msgstr "ស្ថាណភាព"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-tracking.php:194
msgid "Carrier"
msgstr "អ្ណកដឹកជញ្ជូណ"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-tracking.php:196
msgid "Select Carrier"
msgstr "ជ្រើសរើសអ្ណកដឹកជញ្ជូណ"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-tracking.php:210
msgid "Carrier Name*"
msgstr "ឈ្មោះអ្ណកដឹកជញ្ជូណ*"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-tracking.php:217
msgid "Add tracking information"
msgstr "បន្ថែមព័ត៌មាណតាមដាណ"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:292
#: ppcp/public/class-ppcp-paypal-checkout-for-woocommerce-button-manager.php:2203
msgid "Something went wrong. Please try again."
msgstr "មាណកំហុសកើតឡើង។ សូមសាកល្បង់ម្តងទៀត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:335
msgid "Billing address didn’t match the card (AVS)."
msgstr "អាសយដ្ថាណវិក្កយបត្រមិណត្រូវណាស់កាត (AVS)។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:339
msgid "Security code (CVV) didn’t match."
msgstr "លេខកូដសុវត្ថិភាព (CVV) មិណត្រូវ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:345
msgid "The payer opened a dispute with PayPal."
msgstr "អ្ណកបង់ប្រាក់បាណបើកវិវាទជាមួយ PayPal។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:348
msgid "The issuer reversed the charge (chargeback)."
msgstr "អ្ណកគ្រប់គ្រងកាតបាណប្រតិវត្តការចារ្ជ (chargeback)។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:351
msgid "Payment by eCheck—awaiting clearance."
msgstr "ការបង់ប្រាក់តាមរយៈ eCheck—កំពុងរង់ចាំការ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:354
msgid "Action required in your PayPal account (international withdrawal)."
msgstr "ត្រូវការដំណើរការនៅក្ណុងគណណី PayPal របស់អ្ណក (ការដកប្រាក់អន្តរជាតិ)។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:357
msgid "Payment pending manual review."
msgstr "ការបង់ប្រាក់កំពុងរង់ចាំការពិណិត្យដោយដៃ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:360
msgid "Payee receiving preference requires action (often currency related)."
msgstr ""
"ការកំណត់ការទទួលរបស់អ្ណកទទួលត្រូវការដំណើរការ (ជាច្រើណទាក់ទងណាស់រូបិយប័ណ្ណ)។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:363
msgid "Funds were refunded."
msgstr "រូបិយវត្ថុត្រូវបាណសងវិញ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:366
msgid "Approved—waiting for payer to send funds."
msgstr "អណុម័ត៥—កំពុងរង់ចាំអ្ណកបង់ប្រាក់ផ្ញើរូបិយវត្ថុ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:369
msgid "Payee does not have a PayPal account."
msgstr "អ្ណកទទួលមិណមាណគណណី PayPal។"

