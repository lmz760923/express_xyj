msgid "Invalid card expiry date."
msgstr "កាលបរិច្ឆេដផុតកំណត់នៃកាតមិនត្រឹមត្រូវ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1207
msgid "Invalid card security code (CVV)."
msgstr "លេខកូដសុវត្ថិភាពកាត (CVV) មិនត្រឹមត្រូវ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1208
msgid "Invalid transaction state."
msgstr "ស្ថានភាពប្រតិបត្តិការមិនត្រឹមត្រូវ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1209
msgid "Invalid order."
msgstr "ការបញ្ជាទិញមិនត្រឹមត្រូវ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1212
msgid "The card security code (CVV) did not match."
msgstr "លេខកូដសុវត្ថិភាពកាត (CVV) មិនត្រូវ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1213
msgid "Insufficient funds."
msgstr "រូបិយវត្ថុមិនគ្រប់គ្រាន់។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1214
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1225
msgid "Incorrect PIN."
msgstr "PIN មិនត្រឹមត្រូវ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1215
msgid "Too many incorrect PIN attempts."
msgstr "ការបញ្ចូល PIN មិនត្រឹមត្រូវច្រើនពេក។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1216
msgid "This card is closed."
msgstr "កាតនេះត្រូវបានបិទ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1217
msgid "Card capture requested by the bank."
msgstr "ការចាប់យកកាតត្រូវបានស្នើសុំដោយធនាគារ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1218
msgid "User not authorized for this transaction."
msgstr "អ្នកប្រើប្រាស់មិនត្រូវបានអនុញ្ញាតសម្រាប់ប្រតិបត្តិការនេះ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1219
msgid "Address verification failed."
msgstr "ការផ្ទៀងផ្ទាត់អាសយដ្ឋានបានបរាជ័យ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1220
msgid "Invalid or restricted card."
msgstr "កាតមិនត្រឹមត្រូវ ឬត្រូវបានដាក់កម្រិត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1221
msgid "Address verification soft failure."
msgstr "ការផ្ទៀងផ្ទាត់អាសយដ្ឋានបានបរាជ័យដោយម៉ៅត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1222
msgid "Duplicate transaction."
msgstr "ប្រតិបត្តិការស្ទៀន។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1223
msgid "Invalid transaction."
msgstr "ប្រតិបត្តិការមិនត្រឹមត្រូវ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1224
msgid "The card is expired."
msgstr "កាតផុតកំណត់ហើយ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1226
msgid "Strong customer authentication required."
msgstr "ត្រូវការផ្ទៀងផ្ទាត់អតិថិជនមាំនាច់។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1227
msgid "This type of transaction is not permitted."
msgstr "ប្រភេទប្រតិបត្តិការនេះមិនត្រូវបានអនុញ្ញាត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1228
msgid "Too many attempts. Please try again later."
msgstr "ការព្យាយាមច្រើនពេក។ សូមសាកល្បងម្តងទៀតនៅពេលក្រោយ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1229
msgid "Invalid or restricted card. Please use another card."
msgstr "កាតមិនត្រឹមត្រូវ ឬត្រូវបានដាក់កម្រិត។ សូមប្រើកាតផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1230
msgid "Address verification soft failure. Please check your billing address."
msgstr ""
"ការផ្ទៀងផ្ទាត់អាសយដ្ឋានបានបរាជ័យដោយម៉ៅត។ "
"សូមពិនិត្យអាសយដ្ឋានវិក្កយបត្ររបស់អ្នក។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1231
msgid "Duplicate transaction. Please try again."
msgstr "ប្រតិបត្តិការស្ទៀន។ សូមសាកល្បងម្តងទៀត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1232
msgid "Invalid transaction. Please try again."
msgstr "ប្រតិបត្តិការមិនត្រឹមត្រូវ។ សូមសាកល្បងម្តងទៀត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1233
msgid "Expired card. Please use another card."
msgstr "កាតផុតកំណត់ហើយ។ សូមប្រើកាតផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1234
msgid "Incorrect PIN. Please re-enter your PIN."
msgstr "PIN មិនត្រឹមត្រូវ។ សូមបញ្ចូល PIN របស់អ្នកម្តងទៀត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1235
msgid "Strong customer authentication required. Please try again."
msgstr "ត្រូវការផ្ទៀងផ្ទាត់អតិថិជនមាំនាច់។ សូមសាកល្បងម្តងទៀត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1236
msgid "Transaction not permitted. Please use another payment method."
msgstr "ប្រតិបត្តិការមិនត្រូវបានអនុញ្ញាត។ សូមប្រើវិធីបង់ប្រាក់ផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1237
msgid "Transaction attempts exceed limit. Please try again later."
msgstr "ការព្យាយាមប្រតិបត្តិការលើសកំណត់។ សូមសាកល្បងម្តងទៀតនៅពេលក្រោយ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1238
msgid "Reversal rejected. Please contact support."
msgstr "ការប្រតិវត្តត្រូវបានបឋិសេធ។ សូមទាក់ទងផ្នែកគាំទ្រ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1239
msgid "Invalid issue. Please try again."
msgstr "បញ្ហាមិនត្រឹមត្រូវ។ សូមសាកល្បងម្តងទៀត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1240
msgid "Issuer not available. Please try again later."
msgstr "អ្នកគ្រប់គ្រងកាតមិនអាចរកបាន។ សូមសាកល្បងម្តងទៀតនៅពេលក្រោយ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1241
msgid "Issuer temporarily not available. Please try again shortly."
msgstr "អ្នកគ្រប់គ្រងកាតមិនអាចរកបានបណ្តះអាសន្ន។ សូមសាកល្បងម្តងទៀតអីច្រើន។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1242
msgid "Card not activated. Please activate your card and try again."
msgstr ""
"កាតមិនទាន់ត្រូវបានធ្វើសកម្ម។ សូមធ្វើសកម្មកាតរបស់អ្នក ហើយសាកល្បងម្តងទៀត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1243
msgid "Updated card issued. Please use your new card."
msgstr "កាតថ្មីត្រូវបានចេញ។ សូមប្រើកាតថ្មីរបស់អ្នក។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1244
msgid "Account not on file. Please check your card details."
msgstr "គណនេយ្យមិននៅក្នុងឯកសារ។ សូមពិនិត្យមើលព័ត៌មានលម្អិតនៃកាតរបស់អ្នក។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1245
msgid "Approved but not captured. No action needed."
msgstr "អនុម័តប៉ុន្តែមិនត្រូវបានចាប់យក។ មិនចាំបាច់ដំណើរការ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1246
msgid "3DS authentication error. Please try again."
msgstr "កំហុសការផ្ទៀងផ្ទាត់ 3DS។ សូមសាកល្បងម្តងទៀត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1247
msgid "Authentication failed. Please try again."
msgstr "ការផ្ទៀងផ្ទាត់បានបរាជ័យ។ សូមសាកល្បងម្តងទៀត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1248
msgid "BIN error. Please try another card."
msgstr "BIN កំហុស។ សូមសាកល្បងកាតផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1249
msgid "PIN error. Please try again with the correct PIN."
msgstr "PIN កំហុស។ សូមសាកល្បងម្តងទៀតដោយប្រើ PIN ត្រឹមត្រូវ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1250
msgid "Processor system error. Please try again later."
msgstr "កំហុសប្រព័ន្ធដំណើរការ។ សូមសាកល្បងម្តងទៀតនៅពេលក្រោយ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1251
msgid "Host key error. Please try again."
msgstr "កំហុសសោកូញជែ host។ សូមសាកល្បងម្តងទៀត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1252
msgid "Configuration error. Please contact support."
msgstr "កំហុសការកំណត់រចនាសម្ព័ន្ធ។ សូមទាក់ទងផ្នែកគាំទ្រ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1253
msgid "Unsupported operation. Please try another payment method."
msgstr "ប្រតិបត្តិការមិនត្រូវបានគាំទ្រ។ សូមសាកល្បងវិធីបង់ប្រាក់ផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1254
msgid "Communication error. Please try again later."
msgstr "កំហុសការទំនាក់ទំនង។ សូមសាកល្បងម្តងទៀតនៅពេលក្រោយ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1255
msgid "Communication error. Please try again shortly."
msgstr "កំហុសការទំនាក់ទំនង។ សូមសាកល្បងម្តងទៀតអីច្រើន។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1256
msgid "System unavailable. Please try again later."
msgstr "ប្រព័ន្ធមិនអាចប្រើបាន។ សូមសាកល្បងម្តងទៀតនៅពេលក្រោយ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1257
msgid "Transaction declined. Please retry."
msgstr "ប្រតិបត្តិការត្រូវបានបឋិសេធ។ សូមសាកល្បងម្តងទៀត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1258
msgid "Suspected fraud. Please use another payment method."
msgstr "សង្ស័យការប្រតិបត្តិការកេល org។ សូមប្រើវិធីបង់ប្រាក់ផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1259
msgid "Security violation. Please contact your card issuer."
msgstr "ការលើកលែងសុវត្ថិភាព។ សូមទាក់ទងអ្នកគ្រប់គ្រងកាត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1260
msgid "Card reported lost or stolen. Please use another card."
msgstr "កាតត្រូវបានរាយការណ៍បាត់ ឬត្រូវបានលួច។ សូមប្រើកាតផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1261
msgid "Hold - call center. Please contact your card issuer."
msgstr "សូមរោលើក - ត្រូវទាក់ទងមជ្ឈមណ្ឌល។ សូមទាក់ទងអ្នកគ្រប់គ្រងកាត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1262
msgid "Card refused. Please use another payment method."
msgstr "កាតត្រូវបានបឋិសេធ។ សូមប្រើវិធីបង់ប្រាក់ផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1263
msgid "Unrecognized response code. Please try again later."
msgstr "កូដចម្លើយមិនត្រូវបានស្គាល់។ សូមសាកល្បងម្តងទៀតនៅពេលក្រោយ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1264
msgid "Contingencies not resolved. Please try again."
msgstr "លក្ខខណ្ឌណែនាំមិនត្រូវបានដោះស្រាយ។ សូមសាកល្បងម្តងទៀត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1265
#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1278
msgid "CVV verification failed. Please check your CVV."
msgstr "ការផ្ទៀងផ្ទាត់ CVV បានបរាជ័យ។ សូមពិនិត្យមើល CVV របស់អ្នក។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1266
msgid "Account closed. Please use another card."
msgstr "គណនេយ្យត្រូវបានបិទ។ សូមប្រើកាតផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1267
msgid "Reattempt not permitted. Please use another payment method."
msgstr "ការព្យាយាមម្តងទៀតមិនត្រូវបានអនុញ្ញាត។ សូមប្រើវិធីបង់ប្រាក់ផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1268
msgid "Billing address error. Please check your billing details."
msgstr "កំហុសអាសយដ្ឋានវិក្កយបត្រ។ សូមពិនិត្យលម្អិតនៃវិក្កយបត្ររបស់អ្នក។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1269
msgid "Account blocked by issuer. Please contact your card issuer."
msgstr ""
"គណនេយ្យត្រូវបានធ្វើអាសន្នដោយអ្នកគ្រប់គ្រងកាត។ សូមទាក់ទងអ្នកគ្រប់គ្រងកាត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1270
msgid "American Express card disabled. Please use another card."
msgstr "កាត American Express ត្រូវបានបិទ។ សូមប្រើកាតផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1271
msgid "Adult gaming not supported. Please use another payment method."
msgstr "ល្បែងសម្រាប់មនុស្សពេញវ័យមិនត្រូវបានគាំទ្រ។ សូមប្រើវិធីបង់ប្រាក់ផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1272
msgid "Amount incompatible. Please try a different amount."
msgstr "ចំនួនទឹកប្រាក់មិនឆបបសម។ សូមសាកល្បងចំនួនផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1273
msgid "Authorization result error. Please try again."
msgstr "កំហុសលទ្ធផលនៃការអនុញ្ញាត។ សូមសាកល្បងម្តងទៀត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1274
msgid "MCC code error. Please contact support."
msgstr "កំហុសកូដ MCC។ សូមទាក់ទងផ្នែកគាំទ្រ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1275
msgid "Address verification failed. Please check your billing address."
msgstr ""
"ការផ្ទៀងផ្ទាត់អាសយដ្ឋានបានបរាជ័យ។ សូមពិនិត្យអាសយដ្ឋានវិក្កយបត្ររបស់អ្នក។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1276
msgid "Amount exceeded. Please try a smaller amount."
msgstr "ចំនួនទឹកប្រាក់លើស។ សូមសាកល្បងចំនួនតិចជាង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1277
msgid "Gaming transaction error. Please use another payment method."
msgstr "កំហុសប្រតិបត្តិការល្បែង។ សូមប្រើវិធីបង់ប្រាក់ផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1279
msgid "Registration incomplete. Please complete registration."
msgstr "ការចុះឈ្មោះមិនទាន់បញ្ចប់។ សូមបញ្ចប់ការចុះឈ្មោះ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1280
msgid "Country error. Please try another payment method."
msgstr "កំហុសប្រទេស។ សូមសាកល្បងវិធីបង់ប្រាក់ផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1281
msgid "Credit error. Please try another payment method."
msgstr "កំហុសឥណទាន។ សូមសាកល្បងវិធីបង់ប្រាក់ផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1282
msgid "Card type not supported. Please use another card."
msgstr "ប្រភេទកាតមិនត្រូវបានគាំទ្រ។ សូមប្រើកាតផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1283
msgid "Invalid currency. Please select a supported currency."
msgstr "រូបិយប័ណ្ណមិនត្រឹមត្រូវ។ សូមជ្រើសរើសរូបិយប័ណ្ណដែលគាំទ្រ។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1284
msgid "3D Secure authentication error. Please try again."
msgstr "កំហុសការផ្ទៀងផ្ទាត់ 3D Secure។ សូមសាកល្បងម្តងទៀត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1285
msgid "Dynamic currency conversion not supported. Please try again."
msgstr "ការប្តូររូបិយប័ណ្ណថាមវន្តមិនត្រូវបានគាំទ្រ។ សូមសាកល្បងម្តងទៀត។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1286
msgid "Diners Club card rejected. Please use another card."
msgstr "កាត Diners Club ត្រូវបានបឋិសេធ។ សូមប្រើកាតផ្សេង។"

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1287
msgid "Authentication message error. Please try again."
msgstr "កំហុសសារផ្ទៀងផ្ទាត់។ សូមសាកល្បងម្តងទៀត។"

