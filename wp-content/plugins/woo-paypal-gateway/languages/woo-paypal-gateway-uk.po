msgid "Currency validation error. Please select a supported currency."
msgstr "Валідність валюти помилка. Будь ласка, виберіть підтримувану валюту."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1208
msgid "Validation error. Please check your payment details."
msgstr "Помилка перевірки. Перевірте свої платіжні дані."

#: ppcp/includes/ppcp-paypal-checkout-for-woocommerce-function.php:1209
msgid "Virtual terminal not supported. Please try another payment method."
msgstr "Віртуальний термінал не підтримується. Спробуйте інший спосіб оплати."

