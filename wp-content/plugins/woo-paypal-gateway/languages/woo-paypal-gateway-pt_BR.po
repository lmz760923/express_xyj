msgstr "Vá para <strong>Configurações do PayPal</strong>."

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1209
msgid "Find the <strong>Disable Specific Payment Buttons</strong> setting."
msgstr ""
"Encontre a configuração <strong>Desativar Botões de Pagamento Específicos</"
"strong>."

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1210
msgid "Select <strong>Pay Later</strong> from the dropdown list."
msgstr "Selecione <strong>Pagamento Posterior</strong> na lista suspensa."

