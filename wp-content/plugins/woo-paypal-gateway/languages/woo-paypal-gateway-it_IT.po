#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1254
msgid "Click <strong>Save Changes</strong>."
msgstr "Clicca su <strong>Salva modifiche</strong>."

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1217
msgid "How can I show only the \"PayPal\" button on the Checkout page?"
msgstr "Come posso mostrare solo il pulsante \"PayPal\" nella pagina di Checkout?"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1221
msgid ""
"To display only the \"PayPal\" button on the Checkout page, follow these steps:"
msgstr ""
"Per visualizzare solo il pulsante \"PayPal\" nella pagina di Checkout, segui "
"questi passaggi:"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1222
#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1244
msgid "Step 1: Update PayPal Settings"
msgstr "Passo 1: Aggiorna le impostazioni di PayPal"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1225
msgid ""
"Under <strong>Disable Specific Payment Buttons</strong>, select <strong>Credit "
"or Debit Card</strong> and any other methods you want to hide."
msgstr ""
"Sotto <strong>Disabilita Pulsanti di Pagamento Specifici</strong>, seleziona "
"<strong>Carta di Credito o Debito</strong> e qualsiasi altro metodo che "
"desideri nascondere."

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1228
msgid "Step 2: Update Advanced Card Payments Settings"
msgstr "Passo 2: Aggiorna le impostazioni dei pagamenti con carta avanzati"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1230
#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-gateway.php:1252
