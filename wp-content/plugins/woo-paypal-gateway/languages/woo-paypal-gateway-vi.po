msgstr "Vị trí nút PayPal (Chỉ giỏ hàng cổ điển)"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:453
msgid ""
"Choose where the PayPal buttons should appear on the cart page, either above"
" or below the \"Proceed to Checkout\" button. This applies only to classic "
"cart templates, not the new Cart Blocks layout."
msgstr ""
"Chọn vị trí nút PayPal sẽ xuất hiện trên trang giỏ hàng, phía trên hoặc phía"
" dưới nút \"Tiến hành thanh toán\". Điều này chỉ áp dụng cho mẫu giỏ hàng cổ"
" điển, không phải bố cục Cart Blocks mới."

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:457
msgid "Below Proceed to Checkout button"
msgstr "Bên dưới nút Tiến hành thanh toán"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:458
msgid "Above Proceed to Checkout button"
msgstr "Bên trên nút Tiến hành thanh toán"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:556
msgid "Icon"
msgstr "Biểu tượng"

#: ppcp/includes/class-ppcp-paypal-checkout-for-woocommerce-settings.php:560
